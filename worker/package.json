{
  "name": "shiju-api",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:apply:local": "wrangler d1 migrations apply shiju --local",
    "db:apply:remote": "wrangler d1 migrations apply shiju --remote",
    "db:seed:local": "wrangler d1 execute shiju --local --file ./seed.sql",
    "db:seed:remote": "wrangler d1 execute shiju --remote --file ./seed.sql"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "lunar-typescript": "^1.8.6",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "wrangler": "^4.107.0"
  }
}
